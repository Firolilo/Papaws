# Plantilla de secretos para docker-compose.
# Copiá este archivo a `.env` y completá los valores. `.env` NO se commitea.
#   cp .env.example .env
#
# En producción: generá una clave aleatoria fuerte y NO reutilices la de desarrollo.
#   openssl rand -base64 48

# Clave de firma JWT. Mínimo 32 bytes (256 bits) para HMAC-SHA256.
PAPAWS_JWT_KEY=cambiame_por_una_clave_aleatoria_de_al_menos_32_bytes

# Contraseña genérica del modelo de auth de demo (servicio Animales).
PAPAWS_PASSWORD_GENERICA=cambiame
